  connect_bd_net -net xy5_100_0_laser_LPC [get_bd_pins laser_power_test_0/laser_LPC] [get_bd_pins xy5_100_0/laser_LPC]
  connect_bd_net -net xy5_100_0_laser_LPC_data [get_bd_pins laser_power_test_0/laser_LPC_data] [get_bd_pins xy5_100_0/laser_LPC_data]
  connect_bd_net -net xy5_100_0_ledout [get_bd_ports ledout_0] [get_bd_pins xy5_100_0/ledout]
  connect_bd_net -net xy5_100_0_trig [get_bd_ports trig_0] [get_bd_pins xy5_100_0/trig]

  # Create address segments
  assign_bd_address -offset 0x00000000 -range 0x40000000 -target_address_space [get_bd_addr_spaces axi_dma_0/Data_MM2S] [get_bd_addr_segs processing_system7_0/S_AXI_HP0/HP0_DDR_LOWOCM] -force
  assign_bd_address -offset 0x40400000 -range 0x00010000 -target_address_space [get_bd_addr_spaces processing_system7_0/Data] [get_bd_addr_segs axi_dma_0/S_AXI_LITE/Reg] -force


  # Restore current instance
  current_bd_instance $oldCurInst

  validate_bd_design
  save_bd_design
}
# End of create_root_design()


