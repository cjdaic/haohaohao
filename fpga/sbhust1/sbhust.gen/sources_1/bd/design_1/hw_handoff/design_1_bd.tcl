  set CH_X_N_0 [ create_bd_port -dir O CH_X_N_0 ]
  set CH_Y_0 [ create_bd_port -dir O CH_Y_0 ]
  set CH_Y_N_0 [ create_bd_port -dir O CH_Y_N_0 ]
  set CH_Z_0 [ create_bd_port -dir O CH_Z_0 ]
  set CH_Z_N_0 [ create_bd_port -dir O CH_Z_N_0 ]
  set CLK_OUT_AB_1_0 [ create_bd_port -dir O CLK_OUT_AB_1_0 ]
