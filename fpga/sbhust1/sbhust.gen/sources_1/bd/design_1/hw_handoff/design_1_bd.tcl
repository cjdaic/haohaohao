  set CH_B_1_N_0 [ create_bd_port -dir O CH_B_1_N_0 ]
  set CH_B_2_0 [ create_bd_port -dir O CH_B_2_0 ]
  set CH_B_2_N_0 [ create_bd_port -dir O CH_B_2_N_0 ]
